@{
    List<PetShop.Models.TbProduct> product = ViewBag.product as List<PetShop.Models.TbProduct> ?? new List<PetShop.Models.TbProduct>();
}
@{
    var cartItems = ViewBag.cartItems as List<PetShop.Models.CartItem> ?? new List<PetShop.Models.CartItem>();
    decimal cartSubtotal = 0;

    foreach (var item in cartItems)
    {
        decimal itemPrice = item.PriceSale.HasValue && item.PriceSale.Value > 0 ? (decimal)item.PriceSale.Value : (decimal)item.Price;
        decimal itemTotal = itemPrice * item.Quantity; // Sử dụng item.Quantity
        cartSubtotal += itemTotal;
    }
}
@{
    var errorMessage = TempData["Error"] as string;
}
@if (TempData["Error"] != null)
{
    <div class="d-flex justify-content-center mt-3">
        <div class="alert alert-danger text-center w-50">
            @TempData["Error"]
        </div>
    </div>
}


@if (!string.IsNullOrEmpty(errorMessage))
{
    <div class="alert alert-danger alert-dismissible fade show mt-3" role="alert">
        @errorMessage
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Đóng"></button>
    </div>
}

@section Styles {
    <link rel="stylesheet" href="~/assets/css/vendor/font-awesome.min.css" />
    <link rel="stylesheet" href="~/assets/css/vendor/Pe-icon-7-stroke.css" />

    <!-- Plugin CSS (Global Plugins Files) -->
    <link rel="stylesheet" href="~/assets/css/plugins/animate.min.css">
    <link rel="stylesheet" href="~/assets/css/plugins/jquery-ui.min.css">
    <link rel="stylesheet" href="~/assets/css/plugins/swiper-bundle.min.css">
    <link rel="stylesheet" href="~/assets/css/plugins/nice-select.css">
    <link rel="stylesheet" href="~/assets/css/plugins/magnific-popup.min.css" />
    <link rel="stylesheet" href="~/assets/css/style2.css" />
}

@section Scripts {
    <!-- Vendor JS -->
    <script src="~/assets/js/vendor/bootstrap.bundle.min.js"></script>
    <script src="~/assets/js/vendor/jquery-3.5.1.min.js"></script>
    <script src="~/assets/js/vendor/jquery-migrate-3.3.0.min.js"></script>
    <script src="~/assets/js/vendor/modernizr-3.11.2.min.js"></script>
    <script src="~/assets/js/vendor/jquery.waypoints.js"></script>

    <!--Plugins JS-->
    <script src="~/assets/js/plugins/wow.min.js"></script>
    <script src="~/assets/js/plugins/jquery-ui.min.js"></script>
    <script src="~/assets/js/plugins/swiper-bundle.min.js"></script>
    <script src="~/assets/js/plugins/jquery.nice-select.js"></script>
    <script src="~/assets/js/plugins/parallax.min.js"></script>
    <script src="~/assets/js/plugins/jquery.magnific-popup.min.js"></script>

    <script src="~/assets/js/main2.js"></script>
}

<main class="main-content">
    <div class="checkout-area section-space-y-axis-100">
        <div class="container">
            <div class="row">
                <div class="col-12">
                    <div class="coupon-accordion">
                        <h3><i class="bi bi-cart3"></i>Bạn có mã giảm giá? <span id="showcoupon">Nhập mã giảm giá</span></h3>
                        <div id="checkout_coupon" class="coupon-checkout-content">
                            <div class="coupon-info">
                                <form action="javascript:void(0)">
                                    <p class="checkout-coupon">
                                        <input placeholder="Mã giảm giá" type="text">
                                        <input class="coupon-inner_btn" value="Áp dụng phiếu giảm giá" type="submit">
                                    </p>
                                </form>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="row">
                <div class="col-lg-3 col-12">
                    <form action="javascript:void(0)">
                        <div class="checkbox-form">
                            <div class="different-address">
                                <div class="order-notes">
                                    <div class="checkout-form-list checkout-form-list-2">
                                        <label>Ghi chú</label>
                                        <textarea id="checkout-mess" cols="30" rows="10" placeholder="Ghi chú về đơn hàng của bạn"></textarea>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </form>
                </div>
                <div class="col-lg-9 col-12">
                    <div class="your-order">
                        <h3>Đơn hàng của bạn</h3>
                        <div class="your-order-table table-responsive">
                            <table class="table">
                                <thead>
                                    <tr>
                                        <th class="cart-product-name">Sản phẩm</th>
                                        <th class="cart-product-name">Số lượng</th>
                                        <th class="cart-product-total">Tổng cộng</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var item in cartItems)
                                    {
                                        <tr class="cart_item">
                                            <td class="cart-product-name">
                                                @item.Title
                                            </td>
                                            <td class="">
                                                <strong class="product-quantity">
                                                    × @item.Quantity
                                                </strong>
                                            </td>
                                            <td class="cart-product-total">
                                                <span class="amount">
                                                    @if (item.PriceSale == 0)
                                                    {
                                                        <span>@item.Price đ</span>
                                                    }
                                                    else
                                                    {
                                                        <span>@item.PriceSale đ</span>
                                                    }
                                                </span>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                                <tfoot>
                                    <tr class="cart-subtotal">
                                        <th>Tổng cộng</th>
                                        <td><span class="amount">@cartSubtotal đ</span></td>
                                    </tr>
                                    <tr class="order-total">
                                        <th>Tổng tiền</th>
                                        <td><strong><span class="amount">@cartSubtotal đ</span></strong></td>
                                    </tr>
                                </tfoot>
                            </table>
                        </div>
                        <div class="payment-method">
                            <div class="payment-accordion">
                                <div id="accordion">
                                    <form action="/action_page.php">
                                        <input type="checkbox" id="vehicle1" name="vehicle1" value="Bike" style="background-color:aquamarine">
                                        <label for="vehicle1" style="font-size:large; margin-left: 5px">   Thanh toán khi nhận hàng</label><br>
                                        <input type="checkbox" id="vehicle2" name="vehicle2" value="Car">
                                        <label for="vehicle2" style="font-size:large; margin-left: 5px">   Thanh toán qua ngân hàng</label><br>
                                        @* <input type="submit" value="Lọc" style="background-color:aquamarine"> *@
                                    </form>
                                </div>
                                <div class="order-button-payment">
                                    <input value="Thanh toán" type="submit">
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</main>
<script>
    function updateQuantity(productId, change) {
        $.ajax({
            url: '@Url.Action("UpdateQuantity", "Order")',
            type: 'POST',
            data: { id: productId, change: change },
            success: function (response) {
                location.reload();
            }
        });
    }
</script>