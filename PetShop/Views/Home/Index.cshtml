<!-- Team Start -->
<div class="container-fluid py-5">
    <div class="container">
        <div class="border-start border-5 border-primary ps-5 mb-5" style="max-width: 600px;">
            <h6 class="text-primary text-uppercase">Thành viên nhóm</h6>
            <h1 class="display-5 text-uppercase mb-0">Chuyên gia chăm sóc thú cưng có trình độ</h1>
