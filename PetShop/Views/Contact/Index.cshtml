<!-- Contact Start -->
<div class="container-fluid pt-5">
    <div class="container">
        <div class="border-start border-5 border-primary ps-5 mb-5" style="max-width: 600px;">
            <h6 class="text-primary text-uppercase">Liên hệ</h6>
            <h1 class="display-5 text-uppercase mb-0">Xin vui lòng liên hệ với chúng tôi</h1>
        </div>
        <div class="row g-5">
            <div class="col-lg-7">
                <form>
                    <div class="row g-3">
                        <div class="col-12">
                            <input type="text" id="c_name" class="form-control bg-light border-0 px-4" placeholder="Họ tên" style="height: 55px;">
                        </div>
                        <div class="col-12">
                            <input type="email" id="c_phone" class="form-control bg-light border-0 px-4" placeholder="Số điện thoại" style="height: 55px;">
                        </div>
                        <div class="col-12">
                            <input type="text" id="c_email" class="form-control bg-light border-0 px-4" placeholder="Email" style="height: 55px;">
                        </div>
                        <div class="col-12">
                            <textarea id="c_message" class="form-control bg-light border-0 px-4 py-3" rows="8" placeholder="Lời nhắn"></textarea>
                        </div>
                        <div class="col-12">
                            <button id="c_submit" class="btn btn-primary w-100 py-3" type="submit">Gửi</button>
                        </div>
                    </div>
                </form>
            </div>
            <div class="col-lg-5">
                <div class="bg-light mb-5 p-5">
                    <div class="d-flex align-items-center mb-2">
                        <i class="bi bi-geo-alt fs-1 text-primary me-3"></i>
                        <div class="text-start">
                            <h6 class="text-uppercase mb-1">Địa chỉ</h6>
                            <span>125 Lê Lợi, tp.Vinh</span>
                        </div>
                    </div>
                    <div class="d-flex align-items-center mb-2">
                        <i class="bi bi-envelope-open fs-1 text-primary me-3"></i>
                        <div class="text-start">
                            <h6 class="text-uppercase mb-1">Email</h6>
                            <span>dopy@gmail.com</span>
                        </div>
                    </div>
                    <div class="d-flex align-items-center mb-4">
                        <i class="bi bi-phone-vibrate fs-1 text-primary me-3"></i>
                        <div class="text-start">
                            <h6 class="text-uppercase mb-1">Số điện thoại</h6>
                            <span>0396 235 480</span>
                        </div>
                    </div>
                    <div>
                        <iframe class="position-relative w-100"
                                src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3833.913182007519!2d105.67853221481071!3d18.680952387316317!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x3139c52c1fd7bd9b%3A0x1a84ef3d672be7a5!2zxJDGsOG7nW5nIEzDqiBM4bujaSwgVmjDoCwgTmdo4buHIeG7g24gQW4sIFZpZXRuYW0!5e0!3m2!1svi!2s!4v1698746659832!5m2!1svi!2s"
                                frameborder="0" style="height: 205px; border:0;" allowfullscreen="" aria-hidden="false"
                                tabindex="0"></iframe>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
<!-- Contact End -->

@section Scripts{
    <script>
        $(document).ready(function () {
            $("#c_submit").click(function () {
                _name = $("#c_name").val();
                _phone = $("#c_phone").val();
                _email = $("#c_email").val();
                _message = $("#c_message").val();
                $.ajax({
                    url: "/Contact/Create",
                    type: "POST",
                    data: { name: _name, phone: _phone, email: _email, message: _message },
                    success: function (result) {
                        if (result != null) {
                            $("#c_name").val("");
                            $("#c_phone").val("");
                            $("#c_email").val("");
                            $("#c_message").val("");
                            toastr.success('Gửi thành công');
                        }
                        else {
                            toastr.success('Gửi không thành công');
                        }
                    }
                })
            });
        })
    </script>
}