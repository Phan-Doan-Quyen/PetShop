                                                        </div>
                                                    </div>
                                                </div>
                                            </div>
                                        }
                                    </div>
                                </div>
                            </div>
                        </div> *@
                        <div class="widgets-area">
                            <h2 class="widgets-title mb-5">Tag</h2>
                            <div class="widgets-item">
                                <ul class="widgets-tags">
                                    <li>
                                        <a href="javascript:void(0)">Chó</a>
                                    </li>
                                    <li>
                                        <a href="javascript:void(0)">Mèo</a>
                                    </li>
                                    <li>
                                        <a href="javascript:void(0)">Hamster</a>
                                    </li>
                                    <li>
                                        <a href="javascript:void(0)">Quàn áo</a>
                                    </li>
                                </ul>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="col-lg-9 order-1">
                    <div class="product-topbar">
                        <ul>
                            <li class="product-view-wrap">
                                <ul class="nav" role="tablist">
                                    <li class="grid-view" role="presentation">
                                        <a class="active" id="grid-view-tab" data-bs-toggle="tab" href="#grid-view" role="tab" aria-selected="true">
                                            <i class="bi bi-grid-3x3-gap-fill"></i>
                                        </a>
                                    </li>
                                    <li class="list-view" role="presentation">
                                        <a id="list-view-tab" data-bs-toggle="tab" href="#list-view" role="tab" aria-selected="true">
                                            <i class="fa fa-th-list"></i>
                                        </a>
                                    </li>
                                </ul>
                            </li>
                            <li class="page-count">
                                Đã tìm thấy <span>@Model.Count()</span> trong số <span>@Model.Count() </span> sản phẩm
                            </li>
                            <li class="short">
                                <select class="nice-select wide rounded-0">
                                    <option value="1">Tất cả sản phẩm</option>
                                    <option value="2">Dành cho chó</option>
                                    <option value="3">Dành cho mèo</option>
                                    <option value="4">Dành cho chim</option>
                                    <option value="5">dành cho haster</option>
                                </select>
                            </li>
                        </ul>
                    </div>
                    <div class="tab-content text-charcoal pt-8">
                        <div class="tab-pane fade show active" id="grid-view" role="tabpanel" aria-labelledby="grid-view-tab">
                            <div class="product-grid-view row">
                                @foreach (var item in Model)
                                {
                                    string sUrl = $"/product/{item.Alias}-{item.ProductId}.html";
                                    <div class="col-lg-4 col-sm-6 pt-6">
                                        <div class="product-item">
                                            <div class="product-img img-zoom-effect">
                                                <a href="@sUrl">
                                                    <img class="img-full" src="@item.Image" alt="Product Images">
                                                </a>
                                                <div class="product-add-action">
                                                    <ul>
                                                        <li>
                                                            <a data-toggle="tooltip" class="add-to-cart" href="javascript:void(0)" onclick="addToCart(@item.ProductId)" title="Thêm vào giỏ">
                                                                <i class="bi bi-cart3"></i>
                                                            </a>
                                                        </li>
                                                        <li>
                                                            <a href="wishlist.html">
                                                                <i class="bi bi-heart"></i>
                                                            </a>
                                                        </li>
                                                    </ul>
                                                </div>
                                            </div>
                                            <div class="product-content">
                                                <a class="product-name" href="@sUrl">@item.Title</a>
                                                <div class="price-box pb-1">
                                                    @if (item.PriceSale == 0)
                                                    {
                                                        <span class="new-price text-danger">@item.Price đ</span>
                                                    }
                                                    else
                                                    {
                                                        <span class="new-price text-danger">@item.PriceSale đ</span>
                                                        <span class="old-price text-primary">@item.Price đ</span>
                                                    }
                                                </div>
                                                <div class="rating-box">
                                                    <ul>
                                                        @for (var i = 0; i < item.Star; i++)
                                                        {
                                                            <li><i class="bi bi-star-fill"></i></li>
                                                        }
                                                    </ul>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                }
                            </div>
                        </div>
                        <div class="tab-pane fade" id="list-view" role="tabpanel" aria-labelledby="list-view-tab">
                            <div class="product-list-view row">
                                @foreach(var item in Model)
                                {
                                    string sUrl = $"/product/{item.Alias}-{item.ProductId}.html";
                                    <div class="col-12 pt-6">
                                        <div class="product-item">
                                            <div class="product-img img-zoom-effect">
                                                <a href="@sUrl">
                                                    <img class="img-full" src="@item.Image" alt="Product Images">
                                                </a>
                                                <div class="product-add-action">
                                                    <ul>
                                                        <li>
                                                            <a data-toggle="tooltip" class="add-to-cart" href="javascript:void(0)" onclick="addToCart(@item.ProductId)" title="Thêm vào giỏ">
                                                                <i class="bi bi-cart3"></i>
                                                            </a>
                                                        </li>
                                                        <li>
                                                            <a href="wishlist.html">
                                                                <i class="bi bi-heart"></i>
                                                            </a>
                                                        </li>
                                                    </ul>
                                                </div>
                                            </div>
                                            <div class="product-content align-self-center">
                                                <a class="product-name pb-2" href="single-product.html">@item.Title</a>
                                                <div class="price-box pb-1">
                                                    @if (item.PriceSale == 0)
                                                    {
                                                        <span class="new-price text-danger">@item.Price đ</span>
                                                    }
                                                    else
                                                    {
                                                        <span class="new-price text-danger">@item.PriceSale đ</span>
                                                        <span class="old-price text-primary">@item.Price đ</span>
                                                    }
                                                </div>
                                                <div class="rating-box pb-2">
                                                    <ul>
                                                        @for (var i = 0; i < item.Star; i++)
                                                        {
                                                            <li><i class="bi bi-star-fill"></i></li>
                                                        }
                                                    </ul>
                                                </div>
                                                <p class="short-desc mb-0">Li Europan lingues es membres del sam familie. Lor separat existentie es un myth. Por scientie, musica, sport etc, litot Europa usa li sam vocabular. Li lingues differe solmen in li grammatica, li pronunciation e li plu commun vocabules. Omnicos directe al desirabilite de un nov lingua franca: On refusa continuar payar custosi.</p>
                                            </div>
                                        </div>
                                    </div>
                                }
                            </div>
                        </div>
                    </div>
                    <div class="pagination-area pt-10">
                        <nav aria-label="Page navigation example">
                            <ul class="pagination justify-content-center">
                                <li class="page-item">
                                    <a class="page-link" href="#" aria-label="Previous">
                                        <span class="fa fa-chevron-left"></span>
                                    </a>
                                </li>
                                <li class="page-item active"><a class="page-link" href="#">1</a></li>
                                <li class="page-item"><a class="page-link" href="#">2</a></li>
                                <li class="page-item">
                                    <a class="page-link" href="#" aria-label="Next">
                                        <span class="fa fa-chevron-right"></span>
                                    </a>
                                </li>
                            </ul>
                        </nav>
                    </div>
                </div>
            </div>
        </div>
    </div>
</main>
<script>
    function addToCart(productId) {
        $.ajax({
            url: '@Url.Action("AddToCart", "Order")',
            type: 'POST',
            data: { id: productId },
            success: function (response) {
                // Có thể hiển thị thông báo thành công
                alert('Sản phẩm đã được thêm vào giỏ hàng!');
                // Tùy chọn: Cập nhật số lượng giỏ hàng trên giao diện
                // Ví dụ: Cập nhật .product-count trong _Layout.cshtml
                window.location.href = '@Url.Action("Index", "Order")'; // Chuyển hướng đến giỏ hàng
            },
            error: function () {
                alert('Có lỗi xảy ra khi thêm sản phẩm vào giỏ hàng.');
            }
        });
    }
</script>