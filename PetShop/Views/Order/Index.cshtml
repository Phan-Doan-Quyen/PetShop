@{
    List<PetShop.Models.TbProduct> product = ViewBag.product as List<PetShop.Models.TbProduct> ?? new List<PetShop.Models.TbProduct>();
}
@{
    var cartItems = ViewBag.cartItems as List<PetShop.Models.CartItem> ?? new List<PetShop.Models.CartItem>();
    decimal cartSubtotal = 0;

    foreach (var item in cartItems)
    {
        decimal itemPrice = item.PriceSale.HasValue && item.PriceSale.Value > 0 ? (decimal)item.PriceSale.Value : (decimal)item.Price;
        decimal itemTotal = itemPrice * item.Quantity; // Sử dụng item.Quantity
        cartSubtotal += itemTotal;
    }
}
@{
    var errorMessage = TempData["Error"] as string;
}
@if (TempData["Error"] != null)
{
    <div class="d-flex justify-content-center mt-3">
        <div class="alert alert-danger text-center w-50">
            @TempData["Error"]
        </div>
    </div>
}


@if (!string.IsNullOrEmpty(errorMessage))
{
    <div class="alert alert-danger alert-dismissible fade show mt-3" role="alert">
        @errorMessage
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Đóng"></button>
    </div>
}

@section Styles {
    <link rel="stylesheet" href="~/assets/css/vendor/font-awesome.min.css" />
    <link rel="stylesheet" href="~/assets/css/vendor/Pe-icon-7-stroke.css" />

    <!-- Plugin CSS (Global Plugins Files) -->
    <link rel="stylesheet" href="~/assets/css/plugins/animate.min.css">
    <link rel="stylesheet" href="~/assets/css/plugins/jquery-ui.min.css">
    <link rel="stylesheet" href="~/assets/css/plugins/swiper-bundle.min.css">
    <link rel="stylesheet" href="~/assets/css/plugins/nice-select.css">
    <link rel="stylesheet" href="~/assets/css/plugins/magnific-popup.min.css" />
    <link rel="stylesheet" href="~/assets/css/style2.css" />
}

@section Scripts {
    <!-- Vendor JS -->
    <script src="~/assets/js/vendor/bootstrap.bundle.min.js"></script>
    <script src="~/assets/js/vendor/jquery-3.5.1.min.js"></script>
    <script src="~/assets/js/vendor/jquery-migrate-3.3.0.min.js"></script>
    <script src="~/assets/js/vendor/modernizr-3.11.2.min.js"></script>
    <script src="~/assets/js/vendor/jquery.waypoints.js"></script>

    <!--Plugins JS-->
    <script src="~/assets/js/plugins/wow.min.js"></script>
    <script src="~/assets/js/plugins/jquery-ui.min.js"></script>
    <script src="~/assets/js/plugins/swiper-bundle.min.js"></script>
    <script src="~/assets/js/plugins/jquery.nice-select.js"></script>
    <script src="~/assets/js/plugins/parallax.min.js"></script>
    <script src="~/assets/js/plugins/jquery.magnific-popup.min.js"></script>

    <script src="~/assets/js/main2.js"></script>
}

<main class="main-content">
    <div class="cart-area section-space-y-axis-100">
        <div class="container">
            @if (TempData["Message"] != null)
            {
                <div class="alert alert-warning">@TempData["Message"]</div>
            }
            @if (TempData["Error"] != null)
            {
                <div class="alert alert-danger">@TempData["Error"]</div>
            }
        </div>
        <div class="container">
            <div class="row">
                <div class="col-12">
                    <form action="javascript:void(0)">
                        <div class="table-content table-responsive">
                            <table class="table">
                                <thead>
                                    <tr>
                                        <th class="product_remove">Xóa sản phẩm</th>
                                        <th class="product-thumbnail">Hình ảnh</th>
                                        <th class="cart-product-name">Tên sản phẩm</th>
                                        <th class="product-price">Giá</th>
                                        <th class="product-quantity">Số lượng</th>
                                        <th class="product-subtotal">Tổng cộng</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var item in cartItems)
                                    {
                                        decimal itemPrice = item.PriceSale.HasValue && item.PriceSale.Value > 0 ? (decimal)item.PriceSale.Value : (decimal)item.Price;
                                        decimal itemTotal = itemPrice * item.Quantity;
                                        string sUrl = Url.Action("Details", "Product", new { id = item.ProductId });
                                        string sUrl2 = $"/product/{item.Alias}-{item.ProductId}.html";
                                        <tr>
                                            <td class="product_remove">
                                                <a href="@Url.Action("RemoveFromCart", "Order", new { id = item.ProductId })">
                                                    <i class="bi bi-x-square" title="Xóa" style="color:red"></i>
                                                </a>
                                            </td>
                                            <td class="product-thumbnail">
                                                <a href="@sUrl2">
                                                    <img src="@item.Image" alt="Hình ảnh">
                                                </a>
                                            </td>
                                            <td class="product-name"><a href="@sUrl2">@item.Title</a></td>
                                            <td class="product-price">
                                                <span class="amount">
                                                    @if (item.PriceSale == 0)
                                                    {
                                                        <span class="new-price text-danger">@item.Price đ</span>
                                                    }
                                                    else
                                                    {
                                                        <span class="new-price text-danger">@item.PriceSale đ</span>
                                                    }
                                                </span>
                                            </td>
                                            <td class="product-quantity">
                                                <div class="quantity buttons_added">
                                                    <input type="button" class="minus" value="-" onclick="updateQuantity(@item.ProductId, -1)">
                                                    <input type="number" size="4" class="input-text qty text" title="Qty" value="@item.Quantity" min="1" step="1" readonly>
                                                    <input type="button" class="plus" value="+" onclick="updateQuantity(@item.ProductId, 1)">
                                                </div>
                                            </td>
                                            <td class="product-subtotal"><span class="amount">@((item.PriceSale > 0 ? item.PriceSale : item.Price) * item.Quantity) đ</span></td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                        <div class="row">
                            <div class="col-12">
                                <div class="coupon-all">
                                   
                                    <div class="coupon2">
                                        <input class="button" name="update_cart" value="Cập nhật giỏ hàng" type="submit">
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="row">
                            <div class="col-md-5 ml-auto">
                                <div class="cart-page-total">
                                    <h2>Tổng tiền</h2>
                                    <table class="table">
                                        <thead>
                                            <tr>
                                                <th>
                                                    <style>
                                                        .cart-sub-total, .cart-grand-total {
                                                            display: flex;
                                                            justify-content: space-between;
                                                            padding: 5px 0;
                                                            font-size: 16px; 
                                                        }
                                                    </style>

                                                    <div class="cart-sub-total">
                                                        <span>Tổng</span>
                                                        <span>@cartSubtotal đ</span>
                                                    </div>
                                                    <div class="cart-grand-total">
                                                        <span>Tổng đơn hàng</span>
                                                        <span>@cartSubtotal đ</span>
                                                    </div>

                                                </th>
                                            </tr>

                                        </thead><!-- /thead -->
                                        <tbody>
                                            <tr>
                                                <td>
                                                    <form action="/Order/Checkout" method="post">
                                                        <input type="text" name="customerName" placeholder="Họ và tên" required class="form-control mb-2" />
                                                        <input type="text" name="phone" placeholder="Số điện thoại" required class="form-control mb-2" />
                                                        <input type="text" name="address" placeholder="Địa chỉ giao hàng" required class="form-control mb-2" />

                                                        <div class="cart-checkout-btn pull-right mt-2">
                                                            <button type="submit" class="btn btn-primary checkout-btn">
                                                                <a asp-controller="Checkout" asp-action="Index">TIẾN HÀNH THANH TOÁN</a>
                                                            </button>
                                                        </div>
                                                    </form>

                                                </td>
                                            </tr>
                                        </tbody><!-- /tbody -->
                                    </table>
                                </div>
                            </div>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</main>
<script>
    function updateQuantity(productId, change) {
        $.ajax({
            url: '@Url.Action("UpdateQuantity", "Order")',
            type: 'POST',
            data: { id: productId, change: change },
            success: function (response) {
                location.reload();
            }
        });
    }
</script>